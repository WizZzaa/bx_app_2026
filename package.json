{
  "name": "app",
  "productName": "BX Помощник Бухгалтера",
  "version": "2.70.0",
  "description": "BX — помощник бухгалтера Республики Узбекистан: планировщик, калькуляторы, справочники, AI-консультант",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "build": "npm run build:web",
    "build:web": "vite build --config vite.renderer.config.mts --manifest && npm run budget && npm run budget:motion",
    "budget": "node scripts/check-vite-bundle-budget.mjs --profile app",
    "budget:motion": "node scripts/check-motion-mini-budget.mjs",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:bix-frames": "node scripts/validate-bix-frames.mjs",
    "generate:bix-frames": "node scripts/generate-bix-animation-frames.mjs",
    "test:watch": "vitest",
    "dev": "vite --config vite.renderer.config.mts --port 5173",
    "e2e": "bash scripts/e2e/run-smoke.sh",
    "premake": "npm run typecheck && npm run lint && npm test",
    "prepare": "husky || true"
  },
  "keywords": [],
  "author": {
    "name": "WizZzaa",
    "email": "chernikov.dev@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WizZzaa/bx_app_2026.git"
  },
  "homepage": "https://github.com/WizZzaa/bx_app_2026",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "42.4.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "dexie": "^4.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "mammoth": "^1.12.0",
    "motion": "12.42.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tesseract.js": "^7.0.0",
    "update-electron-app": "^3.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
